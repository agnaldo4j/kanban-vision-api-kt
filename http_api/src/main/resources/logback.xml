<configuration>
    <!-- Seleção de formato por include com variável: logback 1.5.x REMOVEU o
         suporte a <if> condicional (Janino) — o condicional antigo era ignorado
         em silêncio e NENHUM root logger era configurado (aplicação muda).
         LOG_FORMAT=json -> logback-json.xml; default -> logback-text.xml. -->
    <include resource="logback-${LOG_FORMAT:-text}.xml"/>

    <logger name="io.ktor" level="INFO"/>
    <logger name="org.jetbrains.exposed" level="INFO"/>
    <logger name="com.kanbanvision" level="DEBUG"/>
</configuration>

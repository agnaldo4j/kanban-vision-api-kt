{
  "permissions": {
    "allow": [
      "Edit(buildSrc/**)",
      "Edit(gradle.properties)",
      "Edit(config/detekt/detekt.yml)",
      "Bash(./gradlew *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git pull *)",
      "Bash(git push origin feat/*)",
      "Bash(git push origin docs/*)",
      "Bash(git push origin fix/*)",
      "Bash(git branch *)",
      "Bash(gh *)",
      "Bash(docker *)",
      "Bash(jq *)",
      "Bash(python3 *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(chmod *)"
    ],
    "deny": [
      "Edit(buildSrc/**)",
      "Edit(gradle.properties)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(rm -rf *)",
      "Edit(config/detekt/detekt.yml)",
      "Edit(.editorconfig)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/guard-commit.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/guard-security.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/guard-security.sh"
          }
        ]
      }
    ]
  }
}

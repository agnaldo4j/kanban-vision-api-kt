# Copy this file to k8s/secrets.env and fill in real values before running
# kubectl apply -k k8s/
# k8s/secrets.env is listed in .gitignore and must never be committed.
DATABASE_PASSWORD=replace-with-real-password
JWT_SECRET=replace-with-real-secret-min-32-chars
# Senha do admin do Grafana (GAP-CB / ADR-0043) — consumida por k8s/14-grafana.yml via secretKeyRef.
GRAFANA_ADMIN_PASSWORD=replace-with-real-admin-password

# Copy this file to .env and fill in your values before running docker-compose.
# .env is listed in .gitignore and must never be committed.

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-local-env

# Opt-in to expose the dev-only token issuance endpoint (/auth/token).
# Never set to true in shared or production environments.
# JWT_DEV_MODE=true
